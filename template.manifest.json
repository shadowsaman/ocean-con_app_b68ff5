    "src/components/ui/toggle.tsx",
    "src/components/ui/tooltip.tsx",
    "src/components/ui/use-toast.tsx"
  ],
  "ai_generated_files": [
    "src/index.css",
    "src/App.tsx",
    "src/components/layout/**",
    "src/features/**",
    "src/pages/**"
  ],
  "merge_strategy": {
    "description": "AI files override static files ONLY if the path is in ai_generated_files. Static files are never overridden unless explicitly listed in the AI response with a special override flag.",
    "override_key": "__override_static__",
    "example": {
      "path": "src/components/ui/button.tsx",
      "__override_static__": true,
      "content": "..."
    }
  },
  "theme_injection": {
    "file": "src/index.css",
    "description": "AI replaces CSS variable values in :root and .dark blocks to match the requested UI style. Variable names are fixed, only HSL values change."
  }
}
